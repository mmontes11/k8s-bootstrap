{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^bootstrap\\.sh$/"
      ],
      "matchStrings": [
        "PROMETHEUS_VERSION=\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "helm",
      "packageNameTemplate": "kube-prometheus-stack",
      "registryUrlTemplate": "https://prometheus-community.github.io/helm-charts"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^bootstrap\\.sh$/"
      ],
      "matchStrings": [
        "CILIUM_VERSION=(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "datasourceTemplate": "helm",
      "packageNameTemplate": "cilium",
      "registryUrlTemplate": "https://helm.cilium.io"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^scripts/containerd\\.sh$/"
      ],
      "matchStrings": [
        "CONTAINERD_VERSION=\\$\\{CONTAINERD_VERSION:-\"?(?<currentValue>[^\"]+)\"?\\}"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "containerd/containerd"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^scripts/kubernetes\\.sh$/"
      ],
      "matchStrings": [
        "KUBERNETES_VERSION=\\$\\{KUBERNETES_VERSION:-\"?(?<currentValue>v[0-9]+\\.[0-9]+)\"?\\}"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "kubernetes/kubernetes"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^scripts/kubernetes\\.sh$/"
      ],
      "matchStrings": [
        "KUBERNETES_PKG=\\$\\{KUBERNETES_PKG:-\"?(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+-[0-9]\\.[0-9])\"?\\}"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "kubernetes/kubernetes"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "github-releases"
      ],
      "matchPackageNames": [
        "kubernetes/kubernetes"
      ],
      "groupName": "Kubernetes"
    }
  ]
}
